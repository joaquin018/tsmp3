{
  "manifest_version": 3,
  "name": "YTMP3 Companion",
  "version": "1.0.0",
  "description": "Companion extension for YTMP3 downloader",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://localhost:8765/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "YTMP3 Companion"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
