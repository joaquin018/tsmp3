<div id="thumbnailContainer">
    <img id="thumbnailImg" src="" alt="" style="opacity: 0; visibility: hidden;" />
    <div class="thumbnail-overlay"></div>
</div>

<form id="downloadForm">
    <div class="input-group">
        <label for="url">URL del Video de YouTube</label>
        <input 
            type="text" 
            id="url" 
            name="url" 
            placeholder="https://www.youtube.com/watch?v=..." 
            required 
        />
    </div>
    <button type="submit" id="downloadBtn">
        <span id="btnText">Descargar MP3</span>
    </button>
</form>

<div id="companionStatus" class="companion-badge" style="display:none;"></div>
<div id="status"></div>

<script>
    const urlInput = document.querySelector('#url') as HTMLInputElement;
    const thumbContainer = document.querySelector('#thumbnailContainer') as HTMLElement;
    const thumbImg = document.querySelector('#thumbnailImg') as HTMLImageElement;
    const form = document.querySelector('#downloadForm');
    const statusDiv = document.querySelector('#status') as HTMLElement;
    const companionStatus = document.querySelector('#companionStatus') as HTMLElement;
    const btn = document.querySelector('#downloadBtn') as HTMLButtonElement;
    const btnText = document.querySelector('#btnText');

    let extensionPresent = false;
    let msgId = 0;
    const pending = new Map<number, (val: any) => void>();

    function getYouTubeID(url: string) {
        const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;
        const match = url.match(regExp);
        return (match && match[2].length === 11) ? match[2] : null;
    }

    let thumbHider: any = null;
    let lastProcessedID: string | null = null;

    thumbImg.onload = () => {
        if (lastProcessedID) {
            thumbImg.style.opacity = '1';
            thumbImg.style.visibility = 'visible';
        }
    };

    async function updateThumbnail(id: string | null) {
        if (id === lastProcessedID) return;
        
        if (id) {
            if (thumbHider) clearTimeout(thumbHider);
            
            if (lastProcessedID) {
                thumbImg.style.opacity = '0';
                await new Promise(r => setTimeout(r, 200));
            }

            thumbImg.style.opacity = '0';
            thumbImg.src = `https://img.youtube.com/vi/${id}/hqdefault.jpg`;
            thumbContainer.style.borderStyle = 'solid';
            
            lastProcessedID = id;
        } else {
            lastProcessedID = null;
            thumbImg.style.opacity = '0';
            thumbContainer.style.borderStyle = 'dashed';
            
            if (thumbHider) clearTimeout(thumbHider);
            thumbHider = setTimeout(() => {
                if (!lastProcessedID) {
                    thumbImg.src = '';
                    thumbImg.style.visibility = 'hidden';
                }
            }, 300);
        }
    }

    urlInput?.addEventListener('input', () => {
        const id = getYouTubeID(urlInput.value);
        updateThumbnail(id);
    });

    // --- Extension Bridge ---
    window.addEventListener('message', (event) => {
        if (event.source !== window) return;
        if (event.data?.type === 'YTMP3_EXTENSION_READY') {
            extensionPresent = true;
            showCompanionBadge('Extension + Companion detected ✅', 'ok');
        }
        if (event.data?.type === 'YTMP3_RESPONSE' || event.data?.type === 'YTMP3_CHECK_RESPONSE') {
            const resolve = pending.get(event.data.id);
            if (resolve) {
                resolve(event.data);
                pending.delete(event.data.id);
            }
        }
    });

    function sendToExtension(type: string, payload: any): Promise<any> {
        return new Promise((resolve) => {
            const id = ++msgId;
            pending.set(id, resolve);
            window.postMessage({ type, id, ...payload }, '*');
            setTimeout(() => {
                if (pending.has(id)) {
                    pending.delete(id);
                    resolve({ connected: false, success: false, error: 'Timeout' });
                }
            }, 3000);
        });
    }

    function showCompanionBadge(text: string, variant: 'ok' | 'error' | 'warn') {
        companionStatus.style.display = 'block';
        companionStatus.textContent = text;
        companionStatus.className = 'companion-badge ' + variant;
    }

    // Check for extension on load
    setTimeout(async () => {
        const res = await sendToExtension('YTMP3_CHECK', {});
        if (res.connected) {
            showCompanionBadge('Companion connected ✅', 'ok');
        } else {
            showCompanionBadge('Companion not running — server fallback', 'warn');
        }
    }, 500);

    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const url = urlInput.value;
        if (!url) return;

        statusDiv.style.display = 'block';
        statusDiv.className = 'status-info';
        statusDiv.innerHTML = '<span class="loader"></span> Procesando...';
        btn.disabled = true;

        // Try extension first
        if (extensionPresent) {
            const res = await sendToExtension('YTMP3_DOWNLOAD', { url, format: 'mp3' });
            if (res.success) {
                statusDiv.className = 'status-success';
                statusDiv.innerHTML = `✅ Descarga iniciada en Companion`;
                btn.disabled = false;
                return;
            } else if (res.error && res.error !== 'Timeout') {
                statusDiv.className = 'status-error';
                statusDiv.innerHTML = `❌ Companion error: ${res.error}`;
                btn.disabled = false;
                return;
            }
        }

        // Fallback to server
        try {
            const response = await fetch('/api/download', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ url })
            });

            const result = await response.json();

            if (response.ok) {
                statusDiv.className = 'status-success';
                statusDiv.innerHTML = `✅ Descarga completada: ${result.filename}`;
            } else {
                statusDiv.className = 'status-error';
                statusDiv.innerHTML = `❌ Error: ${result.error}`;
            }
        } catch (err: any) {
            console.error(`Error de red: ${err.message}`);
            statusDiv.className = 'status-error';
            statusDiv.innerHTML = `❌ Error de red`;
        } finally {
            btn.disabled = false;
            if (btnText) btnText.textContent = 'Descargar MP3';
        }
    });
</script>
